# Server
PORT=3001
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173
JWT_SECRET=change-me-to-a-very-long-random-secret
JWT_REFRESH_SECRET=change-me-to-another-very-long-random-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL_DAYS=7

# Bootstrap admin user
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# Asterisk connectivity
ASTERISK_ENABLED=false
ASTERISK_HOST=127.0.0.1
ASTERISK_AMI_PORT=5038
ASTERISK_AMI_USER=asterisk-admin
ASTERISK_AMI_PASS=change-me
ASTERISK_ARI_URL=http://127.0.0.1:8088
ASTERISK_ARI_USER=asterisk-admin-ari
ASTERISK_ARI_PASS=change-me

# Paths
DATA_DIR=./runtime/data
LOG_DIR=./runtime/logs
ASTERISK_CONFIG_PATH=./runtime/asterisk
ASTERISK_FULL_LOG_FILE=./runtime/logs/asterisk-full.log
PJSIP_MANAGED_FILE=pjsip_admin_generated.conf
DIALPLAN_MANAGED_FILE=extensions_admin_generated.conf
BACKUP_PATH=./runtime/backups

# PM2
PM2_PROCESS_NAME=asterisk-admin-api

# Frontend provisioning display
PROVISIONING_BASE_URL=http://localhost:3001/provisioning
